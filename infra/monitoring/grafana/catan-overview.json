{
  "title": "Catan Online Overview",
  "timezone": "browser",
  "panels": [
    {
      "title": "Command Latency p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(catan_command_latency_seconds_bucket[5m])) by (le, command))"
        }
      ]
    },
    {
      "title": "Validation Failures",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(catan_command_validation_failures_total[5m])) by (command)"
        }
      ]
    },
    {
      "title": "HTTP Throughput",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m]))"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s"
}
